# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Gemini API key — get free at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant — runs locally via Docker, no key needed for local
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Collection name in Qdrant (like a table name)
QDRANT_COLLECTION=rag_documents

# Embedding model — runs on your CPU, no API key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Gemini model to use for generation
GEMINI_MODEL=gemini-2.5-flash-lite

# Upload config
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Chunking config
CHUNK_SIZE=500
CHUNK_OVERLAP=50
